<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Birthday Surprise 🎉</title>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        text-align: center;
        background: linear-gradient(to right, #ff9a9e, #fad0c4);
        overflow: hidden;
    }

    #startScreen, #mainContent {
        position: absolute;
        width: 100%;
        height: 100%;
    }

    #mainContent {
        display: none;
        color: white;
    }

    button {
        padding: 15px 30px;
        font-size: 20px;
        border: none;
        border-radius: 10px;
        background-color: #ff4081;
        color: white;
        cursor: pointer;
        margin-top: 200px;
    }

    h1 {
        font-size: 50px;
        margin-top: 100px;
        animation: glow 1s infinite alternate;
    }

    @keyframes glow {
        from { text-shadow: 0 0 10px white; }
        to { text-shadow: 0 0 30px yellow; }
    }

    .balloons {
        position: absolute;
        bottom: -100px;
        width: 100%;
    }

    .balloon {
        width: 50px;
        height: 70px;
        background: red;
        border-radius: 50%;
        position: absolute;
        animation: float 6s infinite;
    }

    @keyframes float {
        0% { transform: translateY(0); }
        100% { transform: translateY(-800px); }
    }
</style>
</head>

<body>

<!-- Start Screen -->
<div id="startScreen">
    <button onclick="startSurprise()">🎁 Click Here 🎁</button>
</div>

<!-- Main Content -->
<div id="mainContent">
    <h1>🎉 Happy Birthday Madhu 🎂 🎈</h1>
    <h2>Wishing you lots of happiness and success!</h2>

    <div class="balloons">
        <div class="balloon" style="left:10%; background:blue;"></div>
        <div class="balloon" style="left:30%; background:green;"></div>
        <div class="balloon" style="left:50%; background:yellow;"></div>
        <div class="balloon" style="left:70%; background:pink;"></div>
        <div class="balloon" style="left:90%; background:purple;"></div>
    </div>
</div>

<script>
function startSurprise() {
    document.getElementById("startScreen").style.display = "none";
    document.getElementById("mainContent").style.display = "block";

    // Optional: play music
    let audio = new Audio("https://www.fesliyanstudios.com/play-mp3/387");
    audio.play();
}
</script>

</body>
</html>